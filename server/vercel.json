{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "crons": [
    {
      "path": "/api/notifications/scheduler",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/notifications/defer-check",
      "schedule": "* * * * *"
    }
  ]
}
